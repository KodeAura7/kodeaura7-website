NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_byte_hex_secret_here
JWT_EXPIRES_IN=7d

# Seed script (used once to create the first super admin)
SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@kodeaura7.in
SEED_ADMIN_PASSWORD=change_me_immediately

# Cross-environment migration
# MIGRATION_TOKEN must be identical on every server (source and target).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MIGRATION_TOKEN=your_migration_token_here

# Backend API URLs for each environment (NOT the Vercel frontend URLs).
# Use the Render service URL, e.g. https://kodeaura7-api.onrender.com
PRODUCTION_URL=https://your-production-render-url.onrender.com
STAGING_URL=https://your-staging-render-url.onrender.com

# Which environment this server IS (used to prevent migrating to yourself)
CURRENT_ENV=staging
